<%- include('partials/header') %>
<section class="container page-header">
  <div class="card confirmation">
    <p class="eyebrow"><%= t.orderConfirm.title %></p>
    <h1><%= t.orderConfirm.message %></h1>
    <p class="muted"><%= t.orderConfirm.detail %></p>
    <div class="actions">
      <a class="btn btn-danger" href="/cars?lang=<%= lang %>"><%= t.orderConfirm.browse %></a>
