<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= isRtl ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ziane Auto</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;600;700&family=Cairo:wght@400;600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script src="/app.js" defer></script>
</head>
<body class="za-bg">
  <header class="za-navbar">
    <div class="container d-flex align-items-center justify-content-between py-3 gap-3 za-header">
      <a class="za-logo" href="/?lang=<%= lang %>">Ziane Auto</a>
      <nav class="za-nav d-none d-md-flex gap-4">
        <a href="/?lang=<%= lang %>"><%= t.nav.home %></a>
        <a href="/cars?lang=<%= lang %>"><%= t.nav.cars %></a>
      </nav>
      <button class="za-menu d-md-none" type="button" aria-label="Toggle menu">Menu</button>
      <div class="za-lang">
        <a class="za-lang-btn <%= lang === 'en' ? 'active' : '' %>" href="<%= buildLangLink('en') %>">en</a>
        <a class="za-lang-btn <%= lang === 'fr' ? 'active' : '' %>" href="<%= buildLangLink('fr') %>">fr</a>
        <a class="za-lang-btn <%= lang === 'ar' ? 'active' : '' %>" href="<%= buildLangLink('ar') %>">ar</a>
      </div>
    </div>
    <div class="container za-mobile-nav d-md-none">
      <a href="/?lang=<%= lang %>"><%= t.nav.home %></a>
      <a href="/cars?lang=<%= lang %>"><%= t.nav.cars %></a>
    </div>
  </header>
